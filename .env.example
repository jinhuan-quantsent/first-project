# ============================================================
# 基金情绪分析系统 V3.5 - 环境变量模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# --- 数据库配置 ---
# 开发模式默认使用 SQLite，设置 USE_POSTGRES=true 切换为 PostgreSQL
USE_POSTGRES=false
# PostgreSQL 连接（Supabase / 自建）
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/fund_sentiment
# SQLite 路径（开发模式自动使用）
SQLITE_PATH=./data/fund_sentiment.db

# --- Redis 配置 ---
# 开发模式默认使用内存缓存，设置 USE_REDIS=true 切换
USE_REDIS=false
REDIS_URL=redis://default:password@host:6379/0
# Upstash Redis (生产环境)
UPSTASH_REDIS_URL=redis://default:password@host:6379

# --- 数据源配置 ---
# Tushare Pro Token（可选，不填则使用 Mock 数据）
TUSHARE_TOKEN=
# AKShare 数据源（默认启用，免费无需 token）
USE_AKSHARE=true
# 数据缓存过期时间（秒）
DATA_CACHE_TTL=300

# --- 应用配置 ---
APP_NAME=基金情绪分析系统
APP_VERSION=3.5.0
DEBUG=false
SECRET_KEY=change-me-to-a-random-string
API_PREFIX=/api/v1

# --- Celery 配置（可选，开发模式同步执行） ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- 前端配置 ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_TITLE=基金情绪分析系统

# --- 部署环境 ---
ENVIRONMENT=development
# Vercel 部署时设置
VERCEL_URL=
